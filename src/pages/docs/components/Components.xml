<templates>
  <t t-name="Components">
    <div style="max-width: 896px; margin: 0 auto; padding: 32px;">
      <article style="max-width: 65ch;">
        <h1 style="font-size: 2.25rem; font-weight: 700; color: #eee; margin-bottom: 16px;">
          Components</h1>
        <p style="font-size: 1.125rem; color: #9ca3af; margin-bottom: 32px;">
          MetaOWL uses OWL (Odoo Web Library) components for building your UI.
        </p>

        <h2 id="creating-components"
          style="font-size: 1.5rem; font-weight: 600; color: #eee; margin-top: 32px; margin-bottom: 16px;">Creating
          Components</h2>
        <p style="color: #9ca3af; margin-bottom: 16px;">Create components in the <code
            style="background: #374151; padding: 2px 6px; border-radius: 4px; font-size: 0.875rem;">
          src/components/</code> directory:</p>
        <pre class="language-javascript"
          style="background: #1f2937; color: #f9fafb; padding: 16px; border-radius: 8px; overflow-x: auto; font-size: 14px; margin-bottom: 24px;"><code class="language-javascript">// src/components/Button/Button.js
import { Component } from '@odoo/owl'

export class Button extends Component {
  static template = 'Button'
  static props = ['label', 'onClick']
}</code></pre>

        <h2 id="templates"
          style="font-size: 1.5rem; font-weight: 600; color: #eee; margin-top: 32px; margin-bottom: 16px;">
          Templates</h2>
        <p style="color: #9ca3af; margin-bottom: 16px;">Define the component template in an XML
          file:</p>
        <pre class="language-xml"
          style="background: #1f2937; color: #f9fafb; padding: 16px; border-radius: 8px; overflow-x: auto; font-size: 14px; margin-bottom: 24px;"><code class="language-xml">&lt;templates&gt;
  &lt;t t-name="Button"&gt;
    &lt;button class="btn" t-on-click="props.onClick"&gt;
      &lt;t t-esc="props.label"/&gt;
    &lt;/button&gt;
  &lt;/t&gt;
&lt;/templates&gt;</code></pre>

        <h2 id="lifecycle"
          style="font-size: 1.5rem; font-weight: 600; color: #eee; margin-top: 32px; margin-bottom: 16px;">Lifecycle
          Hooks</h2>
        <p style="color: #9ca3af; margin-bottom: 16px;">OWL provides several lifecycle hooks:</p>
        <ul style="color: #9ca3af; margin-bottom: 16px; list-style: disc; padding-left: 24px;">
          <li style="margin-bottom: 8px;"><code
              style="background: #374151; padding: 2px 6px; border-radius: 4px; font-size: 0.875rem;">
            setup()</code> - Called before mounting</li>
          <li style="margin-bottom: 8px;"><code
              style="background: #374151; padding: 2px 6px; border-radius: 4px; font-size: 0.875rem;">
            mounted()</code> - Called after mounting</li>
          <li style="margin-bottom: 8px;"><code
              style="background: #374151; padding: 2px 6px; border-radius: 4px; font-size: 0.875rem;">
            willUnmount()</code> - Called before unmounting</li>
        </ul>
      </article>
    </div>
  </t>
</templates>